      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "eff4yub37gkqod"
          },
          "query": "import \"strings\"\n\nfrom(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cpu\")\n  |> filter(fn: (r) => r.cpu != \"cpu-total\")\n  |> filter(fn: (r) => r._field =~ /usage_.*/)\n  |> filter(fn: (r) => r._field != \"usage_idle\")  // exclude idle\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> pivot(rowKey: [\"_time\", \"cpu\", \"host\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> drop(columns:[\"host\"])\n  |> map(fn: (r) => ({\n      _time: r._time,\n      cpu: strings.toUpper(v: r.cpu),\n      host: r.host,\n      _value: (if exists r.usage_user then r.usage_user else 0.0)\n            + (if exists r.usage_system then r.usage_system else 0.0)\n            + (if exists r.usage_iowait then r.usage_iowait else 0.0)\n            + (if exists r.usage_irq then r.usage_irq else 0.0)\n            + (if exists r.usage_softirq then r.usage_softirq else 0.0)\n            + (if exists r.usage_nice then r.usage_nice else 0.0)\n            + (if exists r.usage_steal then r.usage_steal else 0.0)\n  }))\n  \n  |> yield(name: \"CPU Breakdown\")",
          "refId": "A"
        }
      ],
      "title": "CPU Usage Breakdown per Thread",
      "type": "stat"
    },
